{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "background-800",
                    "color": "#131620",
                    "name": "Background 800"
                },
                {
                    "slug": "background-600",
                    "color": "#1A1D28",
                    "name": "Background 600"
                },
                {
                    "slug": "background-500",
                    "color": "#232734",
                    "name": "Background 500"
                },
                {
                    "slug": "background-200",
                    "color": "#0575B3",
                    "name": "Background 200"
                },
                {
                    "slug": "text-normal",
                    "color": "#F9F4EB",
                    "name": "Text Normal"
                },
                {
                    "slug": "text-subtext",
                    "color": "#E1CDAC",
                    "name": "Text Subtext"
                },
                {
                    "slug": "text-disabled",
                    "color": "#7F7F7F",
                    "name": "Text Disabled"
                },
                {
                    "slug": "accent-green",
                    "color": "#01E3BD",
                    "name": "Accent Green"
                },
                {
                    "slug": "accent-yellow",
                    "color": "#FFDC08",
                    "name": "Accent Yellow"
                },
                {
                    "slug": "accent-orange",
                    "color": "#FF843D",
                    "name": "Accent Orange"
                },
                {
                    "slug": "accent-pink",
                    "color": "#FFBAD5",
                    "name": "Accent Pink"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "\"Outfit\", sans-serif",
                    "name": "Outfit",
                    "slug": "outfit"
                },
                {
                    "fontFamily": "'Cholo Rhita', sans-serif",
                    "name": "Cholo Rhita",
                    "slug": "cholo-rhita",
                    "fontFace": [
                        {
                            "fontFamily": "Cholo Rhita",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./fonts/Cholo Rhita.otf"
                            ]
                        }
                    ]
                },
                {
                    "fontFamily": "'Mallia', sans-serif",
                    "name": "Mallia",
                    "slug": "mallia",
                    "fontFace": [
                        {
                            "fontFamily": "Mallia",
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./fonts/Mallia.ttf"
                            ]
                        }
                    ]
                }
            ],
            "fontSizes": [
                {
                    "slug": "xs",
                    "size": "14px",
                    "name": "XS — 14px"
                },
                {
                    "slug": "sm",
                    "size": "16px",
                    "name": "SM — 16px"
                },
                {
                    "slug": "md",
                    "size": "20px",
                    "name": "MD — 20px"
                },
                {
                    "slug": "lg",
                    "size": "26px",
                    "name": "LG — 26px"
                }
            ]
        },
        "spacing": {
            "spacingSizes": [
                {
                    "name": "3xs",
                    "size": "0.25rem",
