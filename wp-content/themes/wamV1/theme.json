                },
                {
                    "name": "2xs",
                    "size": "0.5rem",
                    "slug": "2xs"
                },
                {
                    "name": "xs",
                    "size": "0.75rem",
                    "slug": "xs"
                },
                {
                    "name": "sm",
                    "size": "1rem",
                    "slug": "sm"
                },
                {
                    "name": "md",
                    "size": "1.25rem",
                    "slug": "md"
                },
                {
                    "name": "lg",
                    "size": "1.5rem",
                    "slug": "lg"
                },
                {
                    "name": "xl",
                    "size": "2rem",
                    "slug": "xl"
                },
                {
                    "name": "2xl",
                    "size": "2.5rem",
                    "slug": "2xl"
                },
                {
                    "name": "3xl",
                    "size": "3rem",
                    "slug": "3xl"
                },
                {
                    "name": "4xl",
                    "size": "3.5rem",
                    "slug": "4xl"
                },
                {
                    "name": "5xl",
                    "size": "4rem",
                    "slug": "5xl"
                },
                {
                    "name": "6xl",
                    "size": "4.5rem",
                    "slug": "6xl"
                },
                {
                    "name": "7xl",
                    "size": "5rem",
                    "slug": "7xl"
                },
                {
                    "name": "8xl",
                    "size": "5.5rem",
                    "slug": "8xl"
                },
                {
                    "name": "9xl",
                    "size": "6rem",
                    "slug": "9xl"
                }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--background-800)",
            "text": "var(--wp--preset--color--text-normal)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--outfit)",
            "fontSize": "20px",
            "lineHeight": "1.25"
        },
        "elements": {
            "h1": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--mallia)",
                    "fontSize": "46px",
                    "lineHeight": "1.3",
                    "fontWeight": "400"
                },
                "color": {
                    "text": "var(--wp--preset--color--accent-yellow)"
                }
            },
            "h2": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--outfit)",
                    "fontSize": "32px",
                    "fontWeight": "700",
                    "lineHeight": "1.1"
                },
                "color": {
                    "text": "var(--wp--preset--color--accent-yellow)"
                }
            },
            "h3": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--outfit)",
                    "fontSize": "28px",
                    "fontWeight": "700",
                    "lineHeight": "1.1"
                },
                "color": {
                    "text": "var(--wp--preset--color--accent-yellow)"
                }
            },
            "h4": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--outfit)",
                    "fontSize": "22px",
                    "fontWeight": "700",
                    "lineHeight": "1.1"
                },
                "color": {
                    "text": "var(--wp--preset--color--accent-yellow)"
                }
            },
            "h5": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--outfit)",
                    "fontSize": "26px",
                    "lineHeight": "1.25"
                },
                "color": {
                    "text": "var(--wp--preset--color--accent-yellow)"
                }
            }
        }
    }
}